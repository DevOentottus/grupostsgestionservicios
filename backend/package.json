{
  "name": "servicio-local-sts-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "build:serverless": "esbuild src/serverless.ts --bundle --platform=node --format=cjs --outfile=dist/serverless.cjs --alias:@=./src --external:sharp && node scripts/copy-pdfkit-data.mjs",
    "start": "node dist/src/app.js",
    "seed": "tsx src/seeds/run.ts",
    "seed:massive": "tsx src/seeds/seed-massive.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/middie": "^9.3.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.0",
    "sharp": "^0.35.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.2",
    "@types/pdfkit": "^0.17.6",
    "@types/sharp": "^0.31.1",
    "@vercel/node": "^5.1.14",
    "esbuild": "^0.25.4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
