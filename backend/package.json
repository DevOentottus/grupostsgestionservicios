{
  "name": "servicio-local-sts-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "build:serverless": "esbuild src/serverless.ts --bundle --platform=node --format=cjs --outfile=dist/serverless.cjs --alias:@=./src",
    "start": "node dist/src/app.js",
    "seed": "tsx src/seeds/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/middie": "^9.3.2",
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "pdfkit": "^0.19.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.2",
    "@types/pdfkit": "^0.17.6",
    "@vercel/node": "^5.1.14",
    "esbuild": "^0.25.4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
