{
  "framework": "vite",
  "installCommand": "npm install --no-audit --no-fund && cd backend && npm install --no-audit --no-fund",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
